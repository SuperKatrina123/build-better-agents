    {"id":"t1","type":"text","x":38,"y":90,"width":184,"height":174,"angle":0,"strokeColor":"#1e3a8a","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":401,"version":1,"versionNonce":401,"isDeleted":false,"boundElements":null,"updated":1700000000000,"link":null,"locked":false,"text":"每次会话开始时\n自动注入上下文\n\n✅ 零延迟\n✅ 始终可见\n❌ 消耗固定预算\n❌ 不适合大量内容\n\n适用：\nrepo-map（≤500 tokens）\n核心约定\n已追齐功能列表","fontSize":12,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":12,"containerId":null,"originalText":"每次会话开始时\n自动注入上下文\n\n✅ 零延迟\n✅ 始终可见\n❌ 消耗固定预算\n❌ 不适合大量内容\n\n适用：\nrepo-map（≤500 tokens）\n核心约定\n已追齐功能列表","lineHeight":1.5,"autoResize":true},
